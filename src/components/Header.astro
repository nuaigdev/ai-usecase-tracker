---
import type { Tracker } from '../types';
import MobileNav from './MobileNav';

interface Props {
  currentTrackerId?: string;
  trackers?: Tracker[];
  showPresent?: boolean;
}
const { currentTrackerId, trackers = [], showPresent = true } = Astro.props;
const presentHref = currentTrackerId ? `/present?tracker=${currentTrackerId}` : '/present';
---
<header class="bg-white border-b border-neutral-200 sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center gap-4">
    <a href="/" class="flex items-center gap-3 flex-shrink-0">
      <img src="/logo.svg" alt="NuAig" class="h-7 w-auto" />
    </a>

    {/* Tracker switcher (desktop) */}
    <nav class="hidden lg:flex items-center gap-1 flex-1 min-w-0 overflow-x-auto no-scrollbar">
      {trackers.map(t => {
        const active = t.id === currentTrackerId;
        return (
          <a
            href={`/?tracker=${t.id}`}
            class={`flex-shrink-0 inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors ${
              active ? 'bg-brand/10 text-brand' : 'text-neutral-600 hover:bg-neutral-100 hover:text-neutral-900'
            }`}
          >
            <span class={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${active ? 'bg-brand' : 'bg-neutral-300'}`} />
            <span class="truncate max-w-[10rem]">{t.title}</span>
          </a>
        );
      })}
    </nav>

    <div class="hidden lg:flex items-center gap-3 flex-shrink-0 ml-auto">
      <a
        href="/admin"
        class="inline-flex items-center gap-2 border border-neutral-300 text-neutral-600 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-neutral-50 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        Manage
      </a>
      {showPresent && (
        <a
          href={presentHref}
          class="inline-flex items-center gap-2 bg-brand text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-[#0587c5] transition-colors shadow-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z" />
          </svg>
          Present
        </a>
      )}
    </div>
    <div class="lg:hidden ml-auto">
      <MobileNav trackers={trackers} currentTrackerId={currentTrackerId} showPresent={showPresent} client:load />
    </div>
  </div>
</header>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
